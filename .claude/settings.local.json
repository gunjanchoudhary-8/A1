{
  "permissions": {
    "allow": [
      "PowerShell(New-Item *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"http://localhost:3000/\" -UseBasicParsing -TimeoutSec 5; \"Status: $\\($r.StatusCode\\)\"; $r.Content.Substring\\(0, [Math]::Min\\(500, $r.Content.Length\\)\\) } catch { \"Error: $\\($_.Exception.Message\\)\" })"
    ]
  }
}
